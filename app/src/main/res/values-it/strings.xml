    <!-- Onboarding -->
    <string name="onboarding_welcome_title">Benvenuto in Keeper</string>
    <string name="onboarding_welcome_subtitle">Il tuo block-notes privato, salvato sul tuo Google Drive.</string>
    <string name="onboarding_intro_long">Keeper è un block-notes veloce e privato per qualsiasi cosa tu voglia ricordare. Scrivi note, allega foto, video e documenti, crea checklist, detta la voce: tutto resta sul tuo Google Drive.</string>
    <string name="onboarding_feature_backup_title">Backup automatico</string>
    <string name="onboarding_feature_backup_body">Ogni nota e allegato viene salvato sul tuo Drive in tempo reale, senza server intermedi.</string>
    <string name="onboarding_feature_private_title">Solo tuo</string>
    <string name="onboarding_feature_private_body">Keeper usa una cartella privata dell\'app. Nessuno tranne te può vedere i file, nemmeno noi.</string>
    <string name="onboarding_feature_restore_title">Ripristino su qualsiasi dispositivo</string>
    <string name="onboarding_feature_restore_body">Reinstalla l\'app e accedi: le tue note tornano con foto e video intatti.</string>
    <string name="onboarding_feature_rich_title">Note ricche</string>
    <string name="onboarding_feature_rich_body">Testo, checklist, foto, video, PDF, ZIP e dettatura vocale: tutto in una singola nota.</string>
    <string name="onboarding_drive_explain">Toccando Collega, Google chiederà una sola volta il permesso. Chiediamo accesso solo ai file che Keeper crea.</string>
