<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Splash screen theme (Android 12+ uses the splashScreen attrs;
         pre-12 falls back to a plain dark theme with a windowBackground). -->
    <style name="Theme.Keeper.Splash" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@color/keeper_splash_bg</item>
        <item name="android:statusBarColor">@color/keeper_splash_bg</item>
        <item name="android:navigationBarColor">@color/keeper_splash_bg</item>
        <item name="android:windowSplashScreenBackground" tools:ignore="NewApi">@color/keeper_splash_bg</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:ignore="NewApi">@mipmap/ic_launcher</item>
    </style>

    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar" />

    <!-- Translucent dialog theme for the widget configuration screen so it
         appears as a centered modal instead of a full-screen activity. -->
    <style name="Theme.Keeper.Dialog" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.55</item>
    </style>
</resources>
