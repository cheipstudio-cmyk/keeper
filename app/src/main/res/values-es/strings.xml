    <string name="onboarding_welcome_title">Bienvenido a Keeper</string>
    <string name="onboarding_welcome_subtitle">Tu cuaderno privado, respaldado en tu propio Google Drive.</string>
    <string name="onboarding_intro_long">Keeper es un cuaderno rápido y privado para todo lo que quieras recordar. Toma notas, adjunta fotos, vídeos y documentos, crea listas, graba la voz: todo permanece en tu propio Google Drive.</string>
    <string name="onboarding_feature_backup_title">Copia automática</string>
    <string name="onboarding_feature_backup_body">Cada nota y adjunto se guarda en tu Drive en tiempo real, sin servidores intermedios.</string>
    <string name="onboarding_feature_private_title">Solo tuyo</string>
    <string name="onboarding_feature_private_body">Keeper usa una carpeta privada de la app. Solo tú puedes ver los archivos, ni siquiera nosotros.</string>
    <string name="onboarding_feature_restore_title">Restaura en cualquier dispositivo</string>
    <string name="onboarding_feature_restore_body">Reinstala la app e inicia sesión: tus notas vuelven con sus fotos y vídeos intactos.</string>
    <string name="onboarding_feature_rich_title">Notas ricas</string>
    <string name="onboarding_feature_rich_body">Texto, listas, fotos, vídeos, PDF, ZIP y dictado por voz: todo cabe en una sola nota.</string>
    <string name="onboarding_drive_explain">Al pulsar Conectar, Google pedirá permiso una vez. Solo solicitamos acceso a los archivos que crea Keeper.</string>
    <string name="onboarding_connect_drive">Conectar Google Drive</string>
